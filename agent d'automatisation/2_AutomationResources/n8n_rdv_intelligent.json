        "calendar": "primary",
        "start": "={{ $json.body.slot }}",
        "end": "={{ new Date(new Date($json.body.slot).getTime() + 30*60000).toISOString() }}",
        "additionalFields": {
          "summary": "=RDV Prestige : {{ $json.body.name }}",
          "description": "={{ $json.body.project }}\nEmail: {{ $json.body.email }}",
          "attendees": [
            "={{ $json.body.email }}"
          ]
        }
      },

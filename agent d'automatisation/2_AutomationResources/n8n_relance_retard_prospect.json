        100,
        300
      ],
      "id": "trigger-id"
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ Math.floor((new Date($node[\"Check Calendar Every Minute\"].json[\"start\"][\"dateTime\"]) - new Date()) / 60000) }}",
              "operation": "equal",
              "value2": 60
            }
          ]
        }
      },
      "name": "Is it H-1?",
